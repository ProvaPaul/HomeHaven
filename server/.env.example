NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/homehaven
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# AI (optional — features fall back to heuristics without a key)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Or use OpenAI instead
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Commute-Time Search (optional — driving works free via OSRM without this;
# add this to enable real walking/cycling routing instead of the heuristic)
# Get a free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=
